{
  "formId": "entry_gate",
  "title": "Entry Gate Form",
  "description": "Standard entry registration form for employees.",
  "fields": [
    {
      "id": "name",
      "label": "Full Name",
      "type": "text",
      "required": true,
      "regex": "^[A-Za-z ]+$",
      "placeholder": "Enter your full name"
    },
    {
      "id": "mobile",
      "label": "Mobile Number",
      "type": "tel",
      "required": true,
      "regex": "^[0-9]{10}$",
      "placeholder": "10-digit mobile number"
    },
    {
      "id": "department",
      "label": "Department",
      "type": "select",
      "options": ["HR", "IT", "Finance", "Operations", "Sales"],
      "required": true
    }
  ],
  "actions": {
    "submitRedirect": "/dashboard",
    "cancelRedirect": "/dashboard"
  }
}
